# ─────────────────────────────────────────────
# Meta WhatsApp Business API Credentials
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# From Meta Developer Dashboard → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=your_permanent_access_token_here

# Your WhatsApp Business phone number ID (not the actual phone number)
PHONE_NUMBER_ID=your_phone_number_id_here

# A secret string YOU choose — must match what you set in Meta webhook config
VERIFY_TOKEN=my_secret_verify_token

# Port for your local server
PORT=3000
