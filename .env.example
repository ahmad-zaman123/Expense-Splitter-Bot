# Meta WhatsApp Business Cloud API
WHATSAPP_TOKEN=your_permanent_access_token_here
PHONE_NUMBER_ID=your_phone_number_id_here
VERIFY_TOKEN=my_secret_verify_token

# Upstash Redis (required in production for persistent sessions)
# Leave blank for local dev — falls back to in-memory store.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Local dev only
PORT=3000
